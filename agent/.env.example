# Groq API key — get a free one at https://console.groq.com/keys
# Required from Phase 3 onward (the LLM). Phases 1 & 2 don't need it.
GROQ_API_KEY=your_groq_key_here

# Optional: override the bun executable path if auto-detection fails.
# (On Windows, the `bun` on PATH is often an npm .cmd shim that Python can't
#  exec directly, so the helper prefers the real bun.exe automatically.)
# BUN_PATH=C:\Users\you\AppData\Roaming\npm\node_modules\bun\bin\bun.exe
