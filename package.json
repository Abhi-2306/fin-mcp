{
  "name": "mcp-finance-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server exposing financial-market data (Alpha Vantage) as tools over stdio.",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "mcp-finance-server": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
